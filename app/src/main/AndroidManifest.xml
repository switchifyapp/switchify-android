<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <queries>
        <!-- Query for all apps with launcher activities -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" /> <!-- Required for camera switches -->
    <uses-permission android:name="android.permission.CAMERA" /> <!-- Required for camera switches -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" /> <!-- Required for foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" /> <!-- Required for camera foreground service -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" /> <!-- Required for recent apps -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" /> <!-- Required for advertising identifier access -->
    <uses-permission android:name="android.permission.WAKE_LOCK" /> <!-- Required for camera service wake lock -->

    <application
        android:name=".SwitchifyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Switchify">
        <activity
            android:name=".activities.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Switchify">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.core.SwitchifyAccessibilityService"
            android:directBootAware="true"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service" />
        </service>

        <service
            android:name=".service.camera.CameraForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="camera"></service>

        <!-- Required: set your sentry.io project identifier (DSN) -->
        <meta-data
            android:name="io.sentry.dsn"
            android:value="https://872454fb270c1a25980e0f339a5db34e@o4509809603575808.ingest.de.sentry.io/4509809608097872" />

        <!-- Sentry privacy-safe defaults: disable noisy/PII-prone features -->
        <meta-data
            android:name="io.sentry.traces.user-interaction.enable"
            android:value="false" />
        <meta-data
            android:name="io.sentry.attach-screenshot"
            android:value="false" />
        <meta-data
            android:name="io.sentry.attach-view-hierarchy"
            android:value="false" />

        <!-- Disable performance tracing by default -->
        <meta-data
            android:name="io.sentry.traces.sample-rate"
            android:value="0.0" />
    </application>

</manifest>
